{% liquid
  assign preset = block.settings.preset_theme | default: 'custom'

  case preset

  when 'oh-so-minimal'
    assign primary     = '#1a1a1a'
    assign heading_clr = '#1a1a1a'
    assign bg_clr      = '#fafafa'
    assign text_clr    = '#111827'
    assign muted_clr   = '#6b7280'
    assign border_clr  = '#d1d5db'
    assign idle_num    = '#d1d5db'
    assign accent_lt   = '#f3f4f6'

  when 'fresh-gradient'
    assign primary     = '#7c3aed'
    assign heading_clr = '#6d28d9'
    assign bg_clr      = '#faf5ff'
    assign text_clr    = '#1e1b4b'
    assign muted_clr   = '#8b5cf6'
    assign border_clr  = '#ddd6fe'
    assign idle_num    = '#c4b5fd'
    assign accent_lt   = '#ede9fe'

  when 'aqua'
    assign primary     = '#0891b2'
    assign heading_clr = '#0e7490'
    assign bg_clr      = '#ecfeff'
    assign text_clr    = '#164e63'
    assign muted_clr   = '#0891b2'
    assign border_clr  = '#a5f3fc'
    assign idle_num    = '#a5f3fc'
    assign accent_lt   = '#cffafe'

  when 'golden-hour'
    assign primary     = '#d97706'
    assign heading_clr = '#b45309'
    assign bg_clr      = '#fffbeb'
    assign text_clr    = '#78350f'
    assign muted_clr   = '#92400e'
    assign border_clr  = '#fde68a'
    assign idle_num    = '#fcd34d'
    assign accent_lt   = '#fef3c7'

  when 'sharp-edge'
    assign primary     = '#000000'
    assign heading_clr = '#000000'
    assign bg_clr      = '#ffffff'
    assign text_clr    = '#000000'
    assign muted_clr   = '#374151'
    assign border_clr  = '#111827'
    assign idle_num    = '#9ca3af'
    assign accent_lt   = '#f3f4f6'

  when 'poseidon'
    assign primary     = '#38bdf8'
    assign heading_clr = '#7dd3fc'
    assign bg_clr      = '#0c1445'
    assign text_clr    = '#e0f2fe'
    assign muted_clr   = '#93c5fd'
    assign border_clr  = '#1e3a5f'
    assign idle_num    = '#1e3a5f'
    assign accent_lt   = '#1e3a5f'

  when 'sand-dunes'
    assign primary     = '#92400e'
    assign heading_clr = '#78350f'
    assign bg_clr      = '#fef9ee'
    assign text_clr    = '#1c1107'
    assign muted_clr   = '#a16207'
    assign border_clr  = '#fde68a'
    assign idle_num    = '#fcd34d'
    assign accent_lt   = '#fef3c7'

  when 'bubblegum'
    assign primary     = '#db2777'
    assign heading_clr = '#be185d'
    assign bg_clr      = '#fdf2f8'
    assign text_clr    = '#500724'
    assign muted_clr   = '#9d174d'
    assign border_clr  = '#f9a8d4'
    assign idle_num    = '#f9a8d4'
    assign accent_lt   = '#fce7f3'

  when 'cape-town'
    assign primary     = '#dc2626'
    assign heading_clr = '#b91c1c'
    assign bg_clr      = '#f8fafc'
    assign text_clr    = '#111827'
    assign muted_clr   = '#6b7280'
    assign border_clr  = '#fca5a5'
    assign idle_num    = '#fca5a5'
    assign accent_lt   = '#fee2e2'

  when 'blackout'
    assign primary     = '#e5e7eb'
    assign heading_clr = '#ffffff'
    assign bg_clr      = '#000000'
    assign text_clr    = '#f9fafb'
    assign muted_clr   = '#9ca3af'
    assign border_clr  = '#374151'
    assign idle_num    = '#374151'
    assign accent_lt   = '#1f2937'

  when 'urban-underground'
    assign primary     = '#a855f7'
    assign heading_clr = '#c084fc'
    assign bg_clr      = '#1e1b4b'
    assign text_clr    = '#ede9fe'
    assign muted_clr   = '#a78bfa'
    assign border_clr  = '#4c1d95'
    assign idle_num    = '#4c1d95'
    assign accent_lt   = '#312e81'

  when 'cyber-pink'
    assign primary     = '#ec4899'
    assign heading_clr = '#f472b6'
    assign bg_clr      = '#0f172a'
    assign text_clr    = '#fdf4ff'
    assign muted_clr   = '#f9a8d4'
    assign border_clr  = '#831843'
    assign idle_num    = '#831843'
    assign accent_lt   = '#500724'

  when 'key-lime-pie'
    assign primary     = '#84cc16'
    assign heading_clr = '#a3e635'
    assign bg_clr      = '#111827'
    assign text_clr    = '#f7fee7'
    assign muted_clr   = '#86efac'
    assign border_clr  = '#365314'
    assign idle_num    = '#365314'
    assign accent_lt   = '#1a2e05'

  when 'lemonade'
    assign primary     = '#ca8a04'
    assign heading_clr = '#a16207'
    assign bg_clr      = '#fefce8'
    assign text_clr    = '#713f12'
    assign muted_clr   = '#854d0e'
    assign border_clr  = '#fef08a'
    assign idle_num    = '#fde047'
    assign accent_lt   = '#fef9c3'

  when 'nile'
    assign primary     = '#f59e0b'
    assign heading_clr = '#fbbf24'
    assign bg_clr      = '#0c1a0e'
    assign text_clr    = '#ecfdf5'
    assign muted_clr   = '#6ee7b7'
    assign border_clr  = '#14532d'
    assign idle_num    = '#14532d'
    assign accent_lt   = '#052e16'

  when 'lavender'
    assign primary     = '#8b5cf6'
    assign heading_clr = '#7c3aed'
    assign bg_clr      = '#f5f3ff'
    assign text_clr    = '#2e1065'
    assign muted_clr   = '#7c3aed'
    assign border_clr  = '#ddd6fe'
    assign idle_num    = '#c4b5fd'
    assign accent_lt   = '#ede9fe'

  when 'magma-lake'
    assign primary     = '#f97316'
    assign heading_clr = '#fb923c'
    assign bg_clr      = '#1c0a00'
    assign text_clr    = '#fff7ed'
    assign muted_clr   = '#fed7aa'
    assign border_clr  = '#7c2d12'
    assign idle_num    = '#7c2d12'
    assign accent_lt   = '#431407'

  when 'smooth-silk'
    assign primary     = '#f43f5e'
    assign heading_clr = '#e11d48'
    assign bg_clr      = '#fff1f2'
    assign text_clr    = '#4c0519'
    assign muted_clr   = '#9f1239'
    assign border_clr  = '#fecdd3'
    assign idle_num    = '#fda4af'
    assign accent_lt   = '#ffe4e6'

  else
    assign primary     = block.settings.primary_color | default: '#2A7A4F'
    assign heading_clr = block.settings.heading_color | default: primary
    assign bg_clr      = block.settings.bg_color      | default: '#ffffff'
    assign text_clr    = block.settings.text_color    | default: '#111827'
    assign muted_clr   = block.settings.muted_color   | default: '#6b7280'
    assign border_clr  = block.settings.border_color  | default: '#e5e7eb'
    assign idle_num    = '#c9ccd0'
    assign accent_lt   = ''

  endcase

  assign h_size     = block.settings.step_heading_size  | default: 26
  assign title_size = block.settings.product_title_size | default: 13
  assign btn_size   = block.settings.btn_font_size      | default: 12
  assign radius     = block.settings.card_radius        | default: 12
  assign radius_sm  = radius | minus: 4
  assign per_row    = block.settings.products_per_row   | default: '4'

  assign h_weight = '800'
  assign h_style  = 'normal'
  if block.settings.heading_style == 'italic'
    assign h_style = 'italic'
  elsif block.settings.heading_style == 'bold-italic'
    assign h_weight = '800'
    assign h_style  = 'italic'
  endif

  assign font_stack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif'
  if block.settings.font_family == 'serif'
    assign font_stack = 'Georgia, "Times New Roman", serif'
  elsif block.settings.font_family == 'mono'
    assign font_stack = '"SF Mono", "Fira Code", "Courier New", monospace'
  elsif block.settings.font_family == 'rounded'
    assign font_stack = '"Nunito", "Quicksand", "Segoe UI", Roboto, sans-serif'
  endif

  if accent_lt == blank
    assign primary_lt = 'color-mix(in srgb, ' | append: primary | append: ' 13%, #fff)'
  else
    assign primary_lt = accent_lt
  endif
  assign primary_hover = 'color-mix(in srgb, ' | append: primary | append: ' 80%, #000)'
  assign primary_glow  = 'color-mix(in srgb, ' | append: primary | append: ' 24%, transparent)'
%}

<div
  id="combo-builder-widget-{{ block.id }}"
  class="combo-builder-root"
  data-shop="{{ shop.permanent_domain }}"
  data-block-id="{{ block.id }}"
  data-cb-instance="{{ block.id }}"
  data-layout="{{ block.settings.layout | default: 'grid' }}"
  data-heading="{{ block.settings.heading_text | escape }}"
  data-currency="{{ cart.currency.iso_code }}"
  data-currency-symbol="{{ cart.currency.symbol }}"
  data-api-base="/apps/combo-builder"
>
  <div class="combo-builder-loading">
    <div class="combo-builder-spinner"></div>
    <span>Loading combo builder…</span>
  </div>
</div>

{{- 'combo-builder.css' | asset_url | stylesheet_tag -}}

{%- comment -%}
  Scoped theme variables — applied to both the widget root AND the sticky footer
  (sticky footer gets [data-cb-instance] set from JS)
{%- endcomment -%}
<style>
  [data-cb-instance="{{ block.id }}"] {
    --cb-primary:             {{ primary }};
    --cb-primary-hover:       {{ primary_hover }};
    --cb-primary-light:       {{ primary_lt }};
    --cb-primary-glow:        {{ primary_glow }};
    --cb-bg:                  {{ bg_clr }};
    --cb-text:                {{ text_clr }};
    --cb-text-muted:          {{ muted_clr }};
    --cb-border:              {{ border_clr }};
    --cb-border-dashed:       {{ border_clr }};
    --cb-idle-num:            {{ idle_num }};
    --cb-font:                {{ font_stack }};
    --cb-step-heading-size:   {{ h_size }}px;
    --cb-step-heading-weight: {{ h_weight }};
    --cb-step-heading-style:  {{ h_style }};
    --cb-product-title-size:  {{ title_size }}px;
    --cb-btn-font-size:       {{ btn_size }}px;
    --cb-radius:              {{ radius }}px;
    --cb-radius-sm:           {{ radius_sm }}px;
    --cb-products-per-row:    {{ per_row }};
  }
  [data-cb-instance="{{ block.id }}"] .cb-step-heading {
    color: {{ heading_clr }};
  }
  [data-cb-instance="{{ block.id }}"] .cb-product-grid {
    grid-template-columns: repeat({{ per_row }}, 1fr);
  }
</style>

<script>
  window.__COMBO_BUILDER__ = window.__COMBO_BUILDER__ || [];
  window.__COMBO_BUILDER__.push({
    mountId:        'combo-builder-widget-{{ block.id }}',
    shop:           '{{ shop.permanent_domain }}',
    currency:       '{{ cart.currency.iso_code }}',
    currencySymbol: '{{ cart.currency.symbol }}',
    layout:         '{{ block.settings.layout | default: "grid" }}',
    apiBase:        '/apps/combo-builder'
  });
</script>
<script defer src="{{ 'combo-builder.js' | asset_url }}"></script>

{% schema %}
{
  "name": "Combo Builder",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Widget Heading",
      "default": "Build Your Own Box!"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Product Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "list", "label": "List" }
      ],
      "default": "grid"
    },

    {
      "type": "header",
      "content": "Color Theme"
    },
    {
      "type": "select",
      "id": "preset_theme",
      "label": "Preset Theme",
      "info": "Pick a ready-made theme. Select 'Custom' to use the color pickers below.",
      "options": [
        { "value": "custom",            "label": "✏️  Custom (use pickers below)" },
        { "value": "oh-so-minimal",     "label": "⚫  Oh So Minimal — Light" },
        { "value": "fresh-gradient",    "label": "🟣  Fresh Gradient — Light" },
        { "value": "aqua",              "label": "🔵  Aqua — Light" },
        { "value": "golden-hour",       "label": "🟡  Golden Hour — Light" },
        { "value": "sharp-edge",        "label": "◼️  Sharp Edge — Light" },
        { "value": "poseidon",          "label": "🌊  Poseidon — Dark" },
        { "value": "sand-dunes",        "label": "🏜️  Sand Dunes — Light" },
        { "value": "bubblegum",         "label": "🩷  Bubblegum — Light" },
        { "value": "cape-town",         "label": "🔴  Cape Town — Light" },
        { "value": "blackout",          "label": "🖤  Blackout — Dark" },
        { "value": "urban-underground", "label": "💜  Urban Underground — Dark" },
        { "value": "cyber-pink",        "label": "🩸  Cyber Pink — Dark" },
        { "value": "key-lime-pie",      "label": "💚  Key Lime Pie — Dark" },
        { "value": "lemonade",          "label": "🍋  Lemonade — Light" },
        { "value": "nile",              "label": "🌿  Nile — Dark" },
        { "value": "lavender",          "label": "🪻  Lavender — Light" },
        { "value": "magma-lake",        "label": "🌋  Magma Lake — Dark" },
        { "value": "smooth-silk",       "label": "🌸  Smooth Silk — Light" }
      ],
      "default": "custom"
    },

    {
      "type": "header",
      "content": "Custom Colors (active when Preset = Custom)"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary / Brand Color",
      "default": "#2A7A4F",
      "info": "Buttons, active borders, slot glow, highlights."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Step Heading Color",
      "default": "#2A7A4F"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Widget Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted / Secondary Text",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card Border Color",
      "default": "#e5e7eb"
    },

    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font Family",
      "options": [
        { "value": "system",  "label": "System (Sans-serif)" },
        { "value": "serif",   "label": "Serif" },
        { "value": "rounded", "label": "Rounded / Friendly" },
        { "value": "mono",    "label": "Monospace" }
      ],
      "default": "system"
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Step Heading Style",
      "options": [
        { "value": "normal",      "label": "Normal" },
        { "value": "italic",      "label": "Italic" },
        { "value": "bold",        "label": "Bold" },
        { "value": "bold-italic", "label": "Bold Italic" }
      ],
      "default": "bold-italic"
    },
    {
      "type": "range",
      "id": "step_heading_size",
      "label": "Step Heading Size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 26
    },
    {
      "type": "range",
      "id": "product_title_size",
      "label": "Product Title Size",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "btn_font_size",
      "label": "Button Font Size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },

    {
      "type": "header",
      "content": "Layout & Shape"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "products_per_row",
      "label": "Products Per Row (Desktop)",
      "options": [
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" },
        { "value": "5", "label": "5 columns" }
      ],
      "default": "4"
    }
  ]
}
{% endschema %}
